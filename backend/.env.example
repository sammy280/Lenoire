DATABASE_URL="postgresql://postgres:password@localhost:5432/sammy_erp"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-secret-key"
JWT_REFRESH_EXPIRES_IN="30d"

PORT=5000
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
ONLINE_STORE_URL=http://localhost:5174

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Sammy Restaurant <noreply@sammyrestaurant.com>"

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Restaurant Settings
RESTAURANT_NAME="Sammy Restaurant & Bar"
DELIVERY_FEE=1000
LOYALTY_RATE=1000
TAX_RATE=0

# Backup
BACKUP_DIR=backups
AUTO_BACKUP_SCHEDULE="0 2 * * *"
